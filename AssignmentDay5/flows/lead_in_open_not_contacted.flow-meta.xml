    <decisions>
        <name>if_more_than_3_days</name>
        <label>if more than 3 days</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>more_than_3</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.LastModifiedDate</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>threedaysbefore</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>email_to_lead_owner</targetReference>
            </connector>
            <label>more than 3</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>numofdays</name>
        <dataType>Number</dataType>
        <expression>NOW() - {!$Record.LastModifiedDate}</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>threedaysbefore</name>
        <dataType>Date</dataType>
        <expression>TODAY() - 3</expression>
    </formulas>
    <interviewLabel>lead in open not contacted {!$Flow.CurrentDateTime}</interviewLabel>
    <label>lead in open not contacted</label>
