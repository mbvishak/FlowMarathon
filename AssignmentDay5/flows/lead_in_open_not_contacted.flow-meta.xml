        <inputParameters>
            <name>emailSubject</name>
            <value>
                <stringValue>lead not contacted yet</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailBody</name>
            <value>
                <stringValue>&lt;p&gt;Your Lead is still in {!$Record.Status} status for last {!numofdays}&lt;/p&gt;</stringValue>
